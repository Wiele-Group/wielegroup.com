# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Cloudflare adapter output (@opennextjs/cloudflare build artifact)
/.open-next/

# Wrangler
.wrangler/
.dev.vars

# typescript
*.tsbuildinfo
next-env.d.ts
/.claude/

# v3.9.1a — build-time observability sidecar written by
# scripts/gen-static-route-lastmod.mjs. Holds the buildTimestamp that
# previously lived as __build in static-route-lastmod.generated.json
# (which dirtied git on every build).
.last-build

# v3.9.4 — Cowork backgrounded-deploy helpers + their stdout log. Local
# tooling only; never repo state. Underscore prefix marks them as
# scratch-tier (mirrors /tmp/ semantics inside the repo root).
/_wiele-deploy.log
/scripts/_wiele-deploy-bg.sh

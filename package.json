{
  "name": "wielegroup",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "gen:lastmod": "node scripts/gen-static-route-lastmod.mjs",
    "indexnow:ping": "node scripts/index-now-ping.mjs",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "build:cf": "npm run gen:lastmod && next build && opennextjs-cloudflare build",
    "preview:cf": "npm run build:cf && wrangler dev",
    "deploy:cf": "npm run build:cf && wrangler deploy && npm run indexnow:ping"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "@types/mdx": "^2.0.13",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.469.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.8.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.19.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vercel/og": "^0.11.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  }
